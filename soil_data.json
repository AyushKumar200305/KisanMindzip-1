  "soil_advice": {
    "alluvial":   {"en": "Maintain regular irrigation and balanced NPK. Add farmyard manure before sowing for best yield.",
                   "hi": "नियमित सिंचाई करें और संतुलित NPK खाद डालें। बुआई से पहले गोबर की खाद मिलाएँ।"},
    "black":      {"en": "Ensure good drainage during monsoon and conserve moisture in summer. Add gypsum if salinity rises.",
                   "hi": "बरसात में जल निकासी का ध्यान रखें और गर्मी में नमी बचाएँ। खारापन बढ़े तो जिप्सम डालें।"},
    "red":        {"en": "Add organic matter and nitrogen-rich fertilizers. Mulching helps retain moisture in dry months.",
                   "hi": "जैविक खाद और नाइट्रोजन वाली खाद डालें। सूखे मौसम में मल्चिंग से नमी बनी रहती है।"},
    "laterite":   {"en": "Apply lime to reduce acidity, add compost regularly, and ensure proper drainage in heavy rains.",
                   "hi": "अम्लीयता कम करने के लिए चूना डालें, नियमित खाद दें, और भारी वर्षा में जल निकासी रखें।"},
    "sandy":      {"en": "Frequent light irrigation and heavy organic mulching are essential. Use drip irrigation if possible.",
                   "hi": "थोड़ी-थोड़ी देर में सिंचाई करें और गोबर खाद से मल्चिंग करें। हो सके तो ड्रिप सिंचाई अपनाएँ।"},
    "mountain":   {"en": "Use terrace farming, add organic compost, and prefer cold-tolerant crops at higher altitudes.",
                   "hi": "सीढ़ीदार खेती करें, गोबर खाद डालें, और ऊँचाई वाले इलाकों में ठंड सहन करने वाली फसलें लगाएँ।"},
    "loamy":      {"en": "Loamy soil is ideal — keep up balanced fertilization, crop rotation, and timely irrigation.",
                   "hi": "दोमट मिट्टी सबसे अच्छी है — संतुलित खाद, फसल चक्र और समय पर सिंचाई करते रहें।"},
    "red_black":  {"en": "Deep ploughing helps. Add organic manure and irrigate during dry spells; drain excess monsoon water.",
                   "hi": "गहरी जुताई करें। गोबर की खाद डालें और सूखे में सिंचाई करें; बरसात का अधिक पानी निकाल दें।"},
    "red_yellow": {"en": "Apply lime to balance pH, add nitrogen, and follow crop rotation with pulses to enrich the soil.",
                   "hi": "pH ठीक रखने के लिए चूना डालें, नाइट्रोजन दें, और दालों के साथ फसल चक्र अपनाएँ।"},
    "coastal":    {"en": "Manage salinity with gypsum, ensure good drainage, and prefer salt-tolerant varieties near coast.",
                   "hi": "जिप्सम से खारापन कम करें, जल निकासी सही रखें, और तट के पास खारी सहनशील किस्में लगाएँ।"},
    "forest":     {"en": "Use organic compost, protect topsoil from erosion, and follow shifting/rotational practices carefully.",
                   "hi": "जैविक खाद डालें, ऊपरी मिट्टी का कटाव रोकें, और फसल चक्र / झूम खेती सावधानी से करें।"}
  },
