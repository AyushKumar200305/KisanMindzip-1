# Copy this file to .env and fill in your real keys.
# NEVER commit the real .env file to git.

# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get a free key at https://data.gov.in (used for live mandi prices)
DATA_GOV_API_KEY=your_data_gov_in_api_key_here

# Optional: only needed if you use gemini_cropdoctor.py
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get a free key at https://openweathermap.org/api (used for the weather widget)
OPENWEATHER_API_KEY=your_openweather_api_key_here
